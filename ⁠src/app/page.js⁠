'use client';
import { useState } from 'react';
import MapContainer from '@/components/Map/MapContainer';
import RoomInterface from '@/components/Video/RoomInterface';
import MessagingOverlay from '@/components/Chat/MessagingOverlay';

export default function Home() {
  const [activeRepo, setActiveRepo] = useState(null);

  return (
    <div style={{ display: 'flex', height: '100%', width: '100%' }}>
      {/* Left Side: Map */}
      <div style={{ flex: activeRepo ? 0.6 : 1, transition: 'all 0.3s' }}>
        <MapContainer onRepoSelect={setActiveRepo} />
      </div>

      {/* Right Side: Video & Chat (Only visible when a repo is selected) */}
      {activeRepo && (
        <div style={{ flex: 0.4, display: 'flex', flexDirection: 'column', borderLeft: '1px solid #ccc' }}>
          <div style={{ padding: '1rem', background: '#f5f5f5' }}>
            <h2>War Room: {activeRepo.name}</h2>
            <button onClick={() => setActiveRepo(null)}>Leave Room</button>
          </div>
          <div style={{ flex: 0.6 }}>
            <RoomInterface repoId={activeRepo.id} />
          </div>
          <div style={{ flex: 0.4, borderTop: '1px solid #ccc' }}>
            <MessagingOverlay />
          </div>
        </div>
      )}
    </div>
  );
}
