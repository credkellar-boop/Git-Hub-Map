export async function getLiveRepos(accessToken) {
  const response = await fetch('https://api.github.com/user/repos', {
    headers: {
      Authorization: `token ${accessToken}`,
    },
  });
  const repos = await response.json();

  // We filter for repos that have 'location' metadata or similar tags
  // For now, we'll map them to random coordinates if metadata is missing
  return repos.map((repo, index) => ({
    id: repo.name,
    name: repo.name,
    // Using a seeded random coordinate based on ID length for demo purposes
    // In production, you would parse repo descriptions for location keywords
    lat: (index * 10) % 90 - 45,
    lng: (index * 20) % 180 - 90,
  }));
}
