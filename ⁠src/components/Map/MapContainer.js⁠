'use client';
import { useState, useEffect } from 'react';
import { useSession } from 'next-auth/react';
import { APIProvider, Map, AdvancedMarker, Pin } from '@vis.gl/react-google-maps';
import { getLiveRepos } from '@/lib/github';

export default function MapContainer({ onRepoSelect }) {
  const { data: session } = useSession();
  const [repos, setRepos] = useState([]);

  useEffect(() => {
    if (session?.accessToken) {
      getLiveRepos(session.accessToken).then(setRepos);
    }
  }, [session]);

  return (
    <APIProvider apiKey={process.env.NEXT_PUBLIC_GOOGLE_MAPS_KEY}>
      <Map defaultCenter={{ lat: 20, lng: 0 }} defaultZoom={2} mapId="GIT_MAP_HUB_THEME">
        {repos.map((repo) => (
          <AdvancedMarker 
            key={repo.id} 
            position={{ lat: repo.lat, lng: repo.lng }}
            onClick={() => onRepoSelect(repo)} 
          >
            <Pin background={'#2ea043'} />
          </AdvancedMarker>
        ))}
      </Map>
    </APIProvider>
  );
}
